# Feature Flags
# Set to "true" to show the full public site. "false" (default) shows the coming soon page.
NEXT_PUBLIC_FEATURE_PUBLIC_SITE=false

# Authentication (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key
CLERK_SECRET_KEY=sk_test_your-secret-key

# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@ep-example-host-pooler.region.aws.neon.tech/neondb?sslmode=require

# File Storage (Cloudflare R2)
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=pto-website
R2_ACCOUNT_ID=your-r2-account-id

# Transactional Email (Resend)
RESEND_API_KEY=re_your-resend-api-key

# Newsletter (MailerLite)
MAILERLITE_API_KEY=your-mailerlite-api-key
MAILERLITE_GROUP_ID=your-mailerlite-group-id

# Sentry (Error Tracking) — optional until M1
SENTRY_DSN=https://your-key@your-org.ingest.us.sentry.io/your-project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-key@your-org.ingest.us.sentry.io/your-project-id
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug
SENTRY_AUTH_TOKEN=sntrys_your-sentry-auth-token

# Upstash Redis (Rate Limiting) — optional until M1
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token
